# HTTP port inside the container / local process (default 8080)
PORT=8080

# Optional: comma-separated browser origins allowed to call the API (enables CORS).
# Example for local Vite + API in Docker on 8080:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: list your real UI origins only (no wildcard).
# CORS_ORIGINS=https://myapp.azurestaticapps.net

CORS_ORIGINS=
